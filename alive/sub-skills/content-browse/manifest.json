{
  "name": "content-browse",
  "display_name": "内容浏览",
  "version": "0.1.0",
  "description": "浏览 Feed 内容并提取灵感素材",
  "intent_bindings": [
    { "intent": "consume", "action": "feed-browse", "priority": 4 },
    { "intent": "learn", "action": "inspiration-collect", "priority": 2 },
    { "intent": "consume", "action": "inspiration-collect", "priority": 2 }
  ],
  "config_schema": {
    "getFeedItems": {
      "type": "function",
      "required": true,
      "description": "Fetch feed items from a platform"
    },
    "searchContent": {
      "type": "function",
      "required": false,
      "description": "Search platform-specific content"
    },
    "webSearch": {
      "type": "function",
      "required": false,
      "description": "General web search function"
    }
  },
  "vitality_cost": { "base": 10 },
  "templates": ["inspiration-summary-prompt.md", "feed-analysis-prompt.md"]
}
