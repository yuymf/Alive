      "required": false,
      "secret": true,
      "description": "fal.ai API key (from env)"
    },
    "image_entry": {
      "type": "string",
      "required": false,
      "default": "AIHUBMIX",
      "description": "Image provider: AIHUBMIX or FAI"
    }
  },
  "feedback_sources": []
}
