{
  "name": "web-search",
  "display_name": "网络搜索研究",
  "version": "0.1.0",
  "description": "好奇心驱动的网络搜索、学习新知识、研究话题",
  "intent_bindings": [
    { "intent": "learn", "action": "search-pipeline", "priority": 5 },
    { "intent": "consume", "action": "search-pipeline", "priority": 4 }
  ],
  "config_schema": {
    "exa_mcp_server": {
      "type": "string",
      "required": false,
      "default": "http://localhost:3100/sse"
    }
  },
  "vitality_cost": { "base": 20 },
  "templates": ["search-digest-prompt.md"]
}
