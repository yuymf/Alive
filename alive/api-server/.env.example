PORT=3001
OPS_API_KEY=change-me-to-a-secure-random-string
ALIVE_PERSONA=miss-v
CORS_ORIGIN=https://your-web-domain.com

# Subprocess timeout for heavy CLI commands (brief/advice/idea/analyze).
# Default 600000 (10 min). Brief typically takes 90–250 s on cold cache.
# CLI_TIMEOUT_MS=600000

# Route LLM calls through OpenClaw main agent (raw assistant, no persona).
# Required when LLM_API_KEY is not set and the default fallback would use
# openclaw/<persona> which may reply conversationally instead of JSON.
# OPENCLAW_AGENT=main
