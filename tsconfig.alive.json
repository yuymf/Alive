{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist-alive",
    "rootDir": "alive",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["alive/scripts/**/*.ts", "alive/sub-skills/**/*.ts"],
  "exclude": ["node_modules", "dist-alive", "**/*.test.ts"]
}
