# ── LLM（可选：留空则使用 OpenClaw 内置 Claude）──────────────────────
# Optional: leave blank to use OpenClaw's built-in Claude model.
LLM_API_KEY=
LLM_API_BASE=         # Default: https://aihubmix.com/v1
LLM_MODEL=            # Default: claude-sonnet-4-20250514

# ── 图片生成（可选，解锁 AI 配图）────────────────────────────────────
# Unlocks AI-generated photos for Instagram posting.
AIHUBMIX_API_KEY=
FAL_KEY=              # Alternative image provider (fal.ai)

# ── 社交平台（可选）──────────────────────────────────────────────────
# Required only for Instagram auto-posting.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
IMGURL_TOKEN=         # Public image hosting (ImgURL)
XHS_SKILLS_DIR=       # Path to xiaohongshu-skills Python directory
