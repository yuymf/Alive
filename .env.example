# Alive Framework — Environment Configuration
# Copy this file to .env and fill in your API keys.
# The installer auto-loads .env from CWD or repo root.
# You can also specify: alive --persona ./persona.yaml --env-file /path/to/.env

# ── Required: LLM API ──
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://aihubmix.com/v1
LLM_MODEL=claude-sonnet-4-20250514

# ── Optional: Image Generation ──
# Used for generating multi-angle reference images from source photo
# AIHUBMIX_API_KEY=sk-your-image-api-key

# ── Optional: Chrome for Platform Skills ──
# The installer auto-detects Chrome/Chromium location.
# Only set these if auto-detection fails:
# CHROME_BIN=/usr/bin/chromium-browser
# CHROME_FLAGS=--no-sandbox --headless=new

# ── Optional: FAL API for alternative image generation ──
# FAL_KEY=your-fal-key
