{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "skill/scripts",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "jimp": ["./node_modules/jimp/dist/commonjs/index.d.ts"]
    }
  },
  "include": ["skill/scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "vitest.config.ts"]
}
